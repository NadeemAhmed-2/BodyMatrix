{
  "expo": {
    "name": "BodyMatrix",
    "slug": "bodymatrix",
    "scheme": "bodymatrix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/BodyMatrix-Logo.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.nadeemahmed.bodymatrix",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#131313",
        "foregroundImage": "./assets/BodyMatrix-Logo.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "658eac0f-1f8a-4982-9784-f33ec89ebacb"
      }
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/BodyMatrix-Logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#131313"
        }
      ]
    ]
  }
}
