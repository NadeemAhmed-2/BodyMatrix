{
  "expo": {
    "name": "BodyMatrix",
    "slug": "bodymatrix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/BodyMatrix-Logo.jpeg",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/BodyMatrix-Logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#131313"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.nadeemahmed.bodymatrix",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#131313",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "658eac0f-1f8a-4982-9784-f33ec89ebacb"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
